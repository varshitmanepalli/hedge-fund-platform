# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=hedgefund

# ─── External Data Sources ────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_KEY=your_alphavantage_key_here   # Optional, fallback to yfinance

# ─── LLM / HuggingFace ───────────────────────────────────────────────────────
HF_API_TOKEN=your_huggingface_token_here
HF_INFERENCE_ENDPOINT=https://api-inference.huggingface.co/models
SENTIMENT_MODEL=ProsusAI/finbert
MACRO_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
USE_LOCAL_LLM=false              # Set true to load model locally

# ─── Platform ─────────────────────────────────────────────────────────────────
ENV=development                  # development | staging | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── Risk Defaults ───────────────────────────────────────────────────────────
DEFAULT_MAX_POSITION_WEIGHT=0.30
DEFAULT_MAX_VAR_95_PCT=0.02
DEFAULT_MIN_SHARPE=0.5
DEFAULT_MAX_DRAWDOWN=0.15
DEFAULT_MAX_LEVERAGE=1.0

# ─── Execution ────────────────────────────────────────────────────────────────
DEFAULT_SLIPPAGE_BPS=5
DEFAULT_COMMISSION_PER_SHARE=0.005
